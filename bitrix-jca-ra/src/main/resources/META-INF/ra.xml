<?xml version="1.0" encoding="UTF-8"?>
<connector xmlns="http://java.sun.com/xml/ns/javaee"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
           http://java.sun.com/xml/ns/javaee/connector_1_6.xsd"
           version="1.6">
    <description>Bitrix24 CRM REST Resource Adapter</description>
    <display-name>Bitrix JCA Resource Adapter</display-name>
    <vendor-name>itmo.blps</vendor-name>
    <eis-type>Bitrix24 REST</eis-type>
    <eis-version>1.0</eis-version>
    <resourceadapter-version>1.0</resourceadapter-version>
    <resourceadapter>
        <resourceadapter-class>itmo.blps.bitrix.jca.BitrixResourceAdapter</resourceadapter-class>
        <outbound-resourceadapter>
            <connection-definition>
                <managedconnectionfactory-class>itmo.blps.bitrix.jca.BitrixManagedConnectionFactory</managedconnectionfactory-class>
                <connectionfactory-interface>itmo.blps.bitrix.jca.BitrixConnectionFactory</connectionfactory-interface>
                <connectionfactory-impl-class>itmo.blps.bitrix.jca.BitrixConnectionFactory</connectionfactory-impl-class>
                <connection-interface>itmo.blps.bitrix.jca.BitrixConnection</connection-interface>
                <connection-impl-class>itmo.blps.bitrix.jca.BitrixConnectionImpl</connection-impl-class>
            </connection-definition>
        </outbound-resourceadapter>
    </resourceadapter>
</connector>
